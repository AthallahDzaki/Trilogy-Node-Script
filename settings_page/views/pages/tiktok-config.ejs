<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('../components/head'); %>
</head>

<body>
  <script src="assets/static/js/initTheme.js"></script>
  <div id="app">
    <%- include('../components/sidebar'); %>
    <div id="main">
      <header class="mb-3">
        <a href="#" class="burger-btn d-block d-xl-none">
          <i class="bi bi-justify fs-3"></i>
        </a>
      </header>
      <div class="page-heading">
        <div class="page-title">
          <div class="row">
            <div class="col-12 col-md-6 order-md-1 order-last">
              <h3>Tiktok Config</h3>
              <p class="text-subtitle text-muted">Place to configure Tiktok Integration for Chaos Mod.</p>
            </div>
          </div>
        </div>

        <!-- Basic Horizontal form layout section start -->
        <section id="basic-horizontal-layouts">
          <div class="row match-height">
            <div class="col-md-12 col-12">
              <div class="card">
                <div class="card-content">
                  <div class="card-body">
                    <form class="form form-horizontal" id="tiktok-config" data-parsley-validate novalidate>
                      <div class="form-body">
                        <div class="row">
                          <div class="col-md-4">
                            <label for="enable-tiktok">Enable Tiktok</label>
                          </div>
                          <div class="col-md-8">
                            <div class="form-group has-icon-left">
                              <div class="position-relative">
                                <select class="form-select" id="enable-tiktok" name="enable-tiktok">
                                  <option value="true">True</option>
                                  <option value="false">False</option>
                                </select>
                              </div>
                            </div>
                          </div>
                          <div class="col-md-4">
                            <label for="enable-tikfinity">Enable Tiktok Interaction</label>
                          </div>
                          <div class="col-md-8">
                            <div class="form-group has-icon-left">
                              <div class="position-relative">
                                <select class="form-select" id="enable-tikfinity" name="enable-tikfinity">
                                  <option value="true">True</option>
                                  <option value="false">False</option>
                                </select>
                              </div>
                            </div>
                          </div>
                          <div class="col-md-4">
                            <label for="enable-tikfinity-http">Enable Tikfinity HTTP Server</label>
                          </div>
                          <div class="col-md-8">
                            <div class="form-group has-icon-left">
                              <div class="position-relative">
                                <select class="form-select" id="enable-tikfinity-http" name="enable-tikfinity-http">
                                  <option value="true">True</option>
                                  <option value="false">False</option>
                                </select>
                              </div>
                            </div>
                          </div>
                          <div class="col-md-4">
                            <label for="seed">Use Build In Chaos</label>
                          </div>
                          <div class="col-md-8">
                            <div class="form-group has-icon-left">
                              <div class="position-relative">
                                <select class="form-select" id="enable-build-in-chaos" name="enable-build-in-chaos">
                                  <option value="true">True</option>
                                  <option value="false">False</option>
                                </select>
                              </div>
                            </div>
                          </div>
                          <div class="col-md-4">
                            <label for="username">Tiktok Username</label>
                          </div>
                          <div class="col-md-8">
                            <div class="form-group has-icon-left">
                              <div class="position-relative">
                                <input type="text" class="form-control" placeholder="@tiktok" id="username" name="username">
                                <div class="form-control-icon">
                                  <i class="fa fa-user-alt"></i>
                                </div>
                              </div>
                            </div>
                          </div>
                          <div class="col-md-4">
                            <label for="session">Tiktok Session ID (Unuseable)</label>
                          </div>
                          <div class="col-md-8">
                            <div class="form-group has-icon-left">
                              <div class="position-relative">
                                <input type="text" class="form-control" placeholder="Session ID" id="session" name="session">
                                <div class="form-control-icon">
                                  <i class="fa fa-id-card"></i>
                                </div>
                              </div>
                            </div>
                          </div>
                          <div class="col-md-4">
                            <label for="enable-vote">Enable Vote</label>
                          </div>
                          <div class="col-md-8">
                            <div class="form-group has-icon-left">
                              <div class="position-relative">
                                <select class="form-select" id="enable-vote" name="enable-vote">
                                  <option value="true">True</option>
                                  <option value="false">False</option>
                                </select>
                              </div>
                            </div>
                          </div>
                          <div class="col-md-4">
                            <label for="vote-cooldown">Vote Cooldown</label>
                          </div>
                          <div class="col-md-8">
                            <div class="form-group has-icon-left">
                              <div class="position-relative">
                                <input type="number" class="form-control" id="vote-cooldown" name="vote-cooldown">
                                <div class="form-control-icon">
                                  <i class="fas fa-clock"></i>
                                </div>
                              </div>
                            </div>
                          </div>
                          <div class="col-md-4">
                            <label for="enable-force-effect">Force Effect</label>
                          </div>
                          <div class="col-md-8">
                            <div class="form-group has-icon-left">
                              <div class="position-relative">
                                <select class="form-select" id="enable-force-effect" name="enable-force-effect">
                                  <option value="true">True</option>
                                  <option value="false">False</option>
                                </select>
                              </div>
                            </div>
                          </div>
                          <div class="col-md-4">
                            <label for="enable-indofinity">Use Indofinity instead Tikfinity</label>
                          </div>
                          <div class="col-md-8">
                            <div class="form-group has-icon-left">
                              <div class="position-relative">
                                <select class="form-select" id="enable-indofinity" name="enable-indofinity">
                                  <option value="true">True</option>
                                  <option value="false">False</option>
                                </select>
                              </div>
                            </div>
                          </div>
                            <button type="submit" class="btn btn-primary me-1 mb-1">Save</button>
                        </div>  
                      </div>
                    </form>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>
      </div>

      <footer>
        <div class="footer clearfix mb-0 text-muted">
          <div class="float-start">
            <p>2024 &copy; Mazer</p>
          </div>
          <div class="float-end">
            <p>Crafted with <span class="text-danger"><i class="bi bi-heart-fill icon-mid"></i></span>
              by <a href="https://saugi.me">Saugi</a> & <a href="https://athallahdzaki.my.id">Athallah Dzaki</a></p>
          </div>
        </div>
      </footer>
    </div>
  </div>
  <script src="assets/static/js/components/dark.js"></script>
  <script src="assets/extensions/perfect-scrollbar/perfect-scrollbar.min.js"></script>
  <script src="assets/extensions/sweetalert2/sweetalert2.all.min.js"></script>
  <script src="assets/compiled/js/app.js"></script>

  <script src="assets/extensions/jquery/jquery.min.js"></script>
  <script src="assets/extensions/parsleyjs/parsley.min.js"></script>
  <script src="assets/tiktok-config.js"></script>
</body>
</html>